# ──────────────────────────────────────────────
# Todo AI API — environment variable template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# Database — SQL Server via aioodbc (Windows Authentication)
# Assembled URL: mssql+aioodbc://@<DB_HOST>/<DB_NAME>
#                ?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
DB_HOST=DESKTOP-RUUEHCT\SQLEXPRESS
DB_NAME=todo_db

# CORS — JSON list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173"]

